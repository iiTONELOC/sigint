{
  "name": "sigint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Anthony Tropeano",
  "repository": {
    "type": "git",
    "url": "https://github.com/iitoneloc/sigint.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "NODE_ENV=production bun src/server/index.prod.ts",
    "build": "bun run build.ts && bun run postbuild.ts",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down -v",
    "docker:prod:up": "PORT=${PORT:-3000} docker compose -f docker-compose.prod.yml up",
    "docker:prod:down": "PORT=${PORT:-3000} docker compose -f docker-compose.prod.yml down",
    "docker:prod:tls:up": "docker compose -f docker-compose.prod.yml --profile tls up",
    "docker:prod:tls:down": "docker compose -f docker-compose.prod.yml --profile tls down",
    "docker:prod:clean": "PORT=${PORT:-3000} docker compose -f docker-compose.prod.yml down -v",
    "docker:clean": "bun run docker:dev:clean",
    "docker:clean:all": "bun run docker:dev:clean && bun run docker:prod:clean && docker image rm sigint-web --force 2>/dev/null || true",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "docker:test": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit",
    "docker:test:clean": "docker compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/ws": "^8.18.1",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
